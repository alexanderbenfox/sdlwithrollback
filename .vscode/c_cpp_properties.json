{
  "configurations": [
    {
      "name": "Mac",
      "includePath": [
        "${workspaceFolder}/src",
        "${workspaceFolder}/build/external/ggpo/include",
        "${workspaceFolder}/imgui",
        "${workspaceFolder}/imgui/impl",
        "/opt/homebrew/include",
        "/opt/homebrew/include/SDL2",
        "/opt/homebrew/opt/jsoncpp/include"
      ],
      "defines": [
        "GL_SILENCE_DEPRECATION"
      ],
      "forcedInclude": [
        "${workspaceFolder}/src/pch.h"
      ],
      "macFrameworkPath": [
        "/Library/Frameworks",
        "/System/Library/Frameworks"
      ],
      "compilerPath": "/usr/bin/clang++",
      "cStandard": "c11",
      "cppStandard": "c++17",
      "intelliSenseMode": "macos-clang-arm64"
    }
  ],
  "version": 4
}
